--- !u!114 &2581342262182416665
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1204515163774073389}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a54ee34a5ea867445b6528831b04ba18, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  targetText: {fileID: 3896079626980638540}
  canvasGroup: {fileID: 6365647733954705668}
  videoController: {fileID: 6382280722364211507}
  sections:
  - name: First
    steps:
    - text: "W roku 2073 na nasz\u0105 planet\u0119 przylecia\u0142a asteroida."
      pauseBeforeSeconds: 0
      newLineBefore: 0
    - text: "Nie by\u0142a ona jak inne, szare g\u0142azy, kt\xF3re wylecia\u0142y
        z lokalnych pas\xF3w asteroid."
      pauseBeforeSeconds: 1
      newLineBefore: 1
    holdAfterTypedSeconds: 1
  - name: Second
    steps:
    - text: "O nie, ta asteroida mia\u0142a zmieni\u0107 kurs naszej historii."
      pauseBeforeSeconds: 0
      newLineBefore: 0
    - text: "Ona jedyna mog\u0142a nas ocali\u0107."
      pauseBeforeSeconds: 1
      newLineBefore: 1
    holdAfterTypedSeconds: 1
  - name: Third
    steps:
    - text: "Pierwsze oznaki niezwyk\u0142o\u015Bci tego meteorytu zaobserwowali\u015Bmy
        niemal natychmiast."
      pauseBeforeSeconds: 0
      newLineBefore: 0
    holdAfterTypedSeconds: 1
  - name: Fourth
    steps:
    - text: "Spalanie by\u0142o znacznie wi\u0119ksze ni\u017C u innych obiekt\xF3w. "
      pauseBeforeSeconds: 0
      newLineBefore: 0
    - text: "Mimo to asteroida nie mala\u0142a."
      pauseBeforeSeconds: 0
      newLineBefore: 1
    holdAfterTypedSeconds: 1
  - name: Fifth
    steps:
    - text: "Rozbi\u0142a si\u0119 na obrze\u017Cach Montrealu."
      pauseBeforeSeconds: 0
      newLineBefore: 0
    - text: Lokalni pasjonaci astronomii szybko odszukali krater.
      pauseBeforeSeconds: 0
      newLineBefore: 1
    holdAfterTypedSeconds: 1
  - name: Sixth
    steps:
    - text: "To co w nim zastali od kilku miesi\u0119cy spe\u0142za sen z powiek
        mnie i innym naukowcom z parku badawczego Reasearch Triangle Park."
      pauseBeforeSeconds: 0
      newLineBefore: 0
    holdAfterTypedSeconds: 1
  typeSecondsPerChar: 0.05
  fadeInSeconds: 0.15
  fadeOutSeconds: 0.6
  holdAfterFadeSeconds: 0.15
  sfxSource: {fileID: 8824162467586934247}
  blipClip: {fileID: 8300000, guid: 8012f8fbd6f63fe4cb8a2703fb96123e, type: 3}
